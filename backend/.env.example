# --------- Server ---------
PORT=4000
NODE_ENV=production

# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_ORIGINS=https://votre-site.com,https://www.votre-site.com

# --------- Database (MySQL) ---------
# Run schema.sql once on this database before starting the server:
#   mysql -u ton_utilisateur -p ton_nom_de_base < schema.sql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=inspei_user
DB_PASSWORD=replace_with_a_strong_password
DB_NAME=inspei_gala

# --------- Auth (participants) ---------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --------- Admin access ---------
# The admin route is intentionally NOT linked anywhere on the public site.
# Change this segment to something only you know, then use it as the URL path.
ADMIN_ROUTE_SECRET=portal-9k2fq7x

# Generate the hash with: npm run hash-admin-password -- "YourStrongPassword"
ADMIN_PASSWORD_HASH=replace_with_generated_hash
ADMIN_JWT_SECRET=replace_with_another_long_random_string
ADMIN_JWT_EXPIRES_IN=12h

# --------- Uploads ---------
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=uploads

# --------- Submission window ---------
# ISO date after which new/edited submissions are rejected (still viewable in admin)
SUBMISSION_DEADLINE=2026-07-16T14:00:00.000Z
